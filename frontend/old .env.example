# ── BACKEND (required) ────────────────────────────────────────────────────────
# Your Railway / Render backend URL. Use http://localhost:8000 for local dev.
VITE_API_URL=http://localhost:8000

# ── FIREBASE (required for auth + data sync) ──────────────────────────────────
# Create a project at https://console.firebase.google.com
# Project Settings → Your apps → Add Web App → copy values below
VITE_FIREBASE_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:xxxxxxxxxxxxxx

# NOTE: Firebase keys in frontend are SAFE to expose — they are not secret.
# They only identify your project. Access is controlled by Firebase Security Rules.
# Your ANTHROPIC_API_KEY stays in the BACKEND .env only — never here.
